# Database (Neon: prefer the pooled connection string for serverless; add in Vercel project env)
DATABASE_URL=

# Bubble
BUBBLE_API_TOKEN=
# Optional overrides (see server/lib/ingestion.ts)
# BUBBLE_API_BASE_URL=
# BUBBLE_HOSPITAL_INTERNAL_NAME_FIELD=Internal Name
# BUBBLE_CREATED_DATE_FIELD=Created Date
# BUBBLE_MODIFIED_DATE_FIELD=Modified Date

# Dashboard auth
DASHBOARD_PASSWORD=
DASHBOARD_AUTH_SECRET=

# Ingestion (API key for POST /api/ingest from automation)
# INGEST_API_KEY=

# Vercel Cron: must match Project Settings → Cron Jobs secret (Authorization: Bearer …)
# CRON_SECRET=

# Cron / default ingest: wall-clock per pass (ms). Increase if many Hospital lookups time out.
INGEST_MAX_DURATION_MS=60000
# Max multi-pass iterations per scheduled run (each pass uses INGEST_MAX_DURATION_MS)
INGEST_SCHEDULE_MAX_PASSES=12

# Dashboard Refresh → Bubble sync (session-protected POST /api/sync/bubble)
DASHBOARD_BUBBLE_SYNC=false
# Per-pass duration for dashboard-triggered sync (ms)
DASHBOARD_SYNC_MAX_DURATION_MS=90000
DASHBOARD_SYNC_MAX_PASSES=15
